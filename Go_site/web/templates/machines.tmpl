{{ define "machines.tmpl" }}
<!DOCTYPE html>
<html>
<head>
  <title>My machines</title>
  <style>
    :root {
      --bg-main: #0b0b0d;
      --bg-card: #141416;
      --bg-row-alt: #191b1f;
      --border-color: #26282f;
      --accent: #52e36a;
      --accent-soft: #3ac458;
      --text-main: #f5f5f7;
      --text-muted: #a0a3ad;
      --status-green: #2ecc71;
      --status-yellow: #f1c40f;
      --status-red: #e74c3c;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 24px;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background-color: var(--bg-main);
      color: var(--text-main);
    }

    h1 {
      margin: 0;
      font-size: 24px;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .page-header-title {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .page-subtitle {
      font-size: 12px;
      color: var(--text-muted);
    }

    .card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 16px;
      box-shadow: 0 6px 12px rgba(0,0,0,0.35);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
    }

    th, td {
      padding: 8px 6px;
      font-size: 13px;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      text-align: left;
      font-weight: 600;
      color: var(--text-muted);
    }

    tr:nth-child(even) td {
      background-color: var(--bg-row-alt);
    }

    tr:hover td {
      background-color: #202228;
    }

    .col-ip { width: 220px; }
    .col-actions { width: 120px; }

    .tag {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 2px 10px;
      border-radius: 999px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 600;
      border: 1px solid transparent;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background-color: currentColor;
    }

    .status-ready {
      color: var(--status-green);
      background-color: rgba(46, 204, 113, 0.12);
      border-color: rgba(46, 204, 113, 0.35);
    }

    .status-pending {
      color: var(--status-yellow);
      background-color: rgba(241, 196, 15, 0.12);
      border-color: rgba(241, 196, 15, 0.40);
    }

    .status-failed {
      color: var(--status-red);
      background-color: rgba(231, 76, 60, 0.12);
      border-color: rgba(231, 76, 60, 0.45);
    }

    .ip-pill {
      font-size: 12px;
      background-color: #1c1e23;
      padding: 3px 10px;
      border-radius: 999px;
      border: 1px solid var(--border-color);
      color: var(--text-main);
      white-space: nowrap;
    }

    .ip-pill-muted {
      font-size: 12px;
      color: var(--text-muted);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 4px 10px;
      font-size: 12px;
      border-radius: 4px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background-color 0.15s ease, transform 0.05s ease;
    }

    .btn-primary {
      background-color: var(--accent);
      color: #000;
      font-weight: 600;
      border-radius: 999px;
    }

    .btn-primary:hover {
      background-color: var(--accent-soft);
    }

    .btn-danger {
      background-color: #dc3545;
      border-radius: 999px;
      border: 1px solid #dc3545;
      color: #fff;
      padding: 3px 10px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 600;
    }

    .btn-danger:hover {
      background-color: #e55361;
    }

    .btn-sm {
      padding: 2px 8px;
      font-size: 11px;
    }

    a {
      color: var(--accent);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    .empty-state {
      font-size: 13px;
      color: var(--text-muted);
      padding-top: 4px;
    }
  </style>
</head>
<body>
  <div class="page-header">
    <div class="page-header-title">
      <h1>My machines</h1>
      <span class="page-subtitle">Services in your namespace</span>
    </div>
    <a class="btn btn-primary" href="/me/machines/new">New machine</a>
  </div>

  <div class="card">
    {{ if eq (len .Machines) 0 }}
      <div class="empty-state">
        You don't have any machines yet. Click "New machine" to create one.
      </div>
    {{ else }}
      <table id="machines-table">
        <tr>
          <th>Name</th>
          <th>Service</th>
          <th>Status</th>
          <th>Resources</th>
          <th class="col-ip">Address</th>
          <th class="col-actions">Actions</th>
        </tr>
        {{ range .Machines }}
        <tr data-machine-id="{{ .ID }}">
          <td class="machine-name">{{ .Name }}</td>

          <td>
            <span class="tag">
              {{ if eq .ServiceKind "web" }}
                Web application
              {{ else if eq .ServiceKind "job" }}
                Background job
              {{ else }}
                {{ .ServiceKind }}
              {{ end }}
            </span>
          </td>

          <td class="machine-status">
            {{ if eq .Status "ready" }}
              <span class="status-badge status-ready">
                <span class="status-dot"></span> ready
              </span>
            {{ else if eq .Status "failed" }}
              <span class="status-badge status-failed">
                <span class="status-dot"></span> failed
              </span>
            {{ else }}
              <span class="status-badge status-pending">
                <span class="status-dot"></span> pending
              </span>
            {{ end }}
          </td>

          <td>
            <span class="tag">
              {{ if eq .ResourcesPreset "small" }}
                 50m CPU / 64Mi RAM
              {{ else if eq .ResourcesPreset "medium" }}
                 100m CPU / 128Mi RAM
              {{ else if eq .ResourcesPreset "large" }}
                 250m CPU / 256Mi RAM
              {{ else }}
                • {{ .ResourcesPreset }}
              {{ end }}
            </span>
          </td>

          <td class="machine-ip">
            {{ if .ExternalIP }}
              {{ if .IngressHost }}
                <span class="ip-pill">{{ .IngressHost }} / {{ .ExternalIP }}</span>
              {{ else }}
                <span class="ip-pill">{{ .ExternalIP }}</span>
              {{ end }}
            {{ else if .IngressHost }}
              <span class="ip-pill">{{ .IngressHost }}</span>
            {{ else if eq .AccessScope "internal" }}
              <span class="ip-pill">
                {{ .Username }}-{{ .Name }}.{{ .Username }}
              </span>
            {{ else }}
              <span class="ip-pill-muted">waiting...</span>
            {{ end }}
          </td>
          
          <td>
            <a href="/me/machines/{{ .ID }}/edit" class="btn btn-sm btn-primary" style="margin-right: 4px;">
              Edit
            </a>
            <form action="/me/machines/{{ .ID }}/delete" method="post" style="display:inline;">
              <button type="submit" class="btn btn-danger btn-sm">
                Delete
              </button>
            </form>
          </td>
        </tr>
        {{ end }}
      </table>
    {{ end }}
  </div>

  <script>
    (function() {
      const table = document.getElementById('machines-table');
      if (!table) return;

      const POLL_INTERVAL_MS = 3000;

      function renderStatusBadge(status) {
        const span = document.createElement('span');
        span.classList.add('status-badge');
        const s = (status || '').toLowerCase();
        if (s === 'ready') span.classList.add('status-ready');
        else if (s === 'failed') span.classList.add('status-failed');
        else span.classList.add('status-pending');

        const dot = document.createElement('span');
        dot.classList.add('status-dot');
        span.appendChild(dot);

        span.appendChild(document.createTextNode(' ' + (s || 'pending')));
        return span;
      }

      function updateRow(row, m) {
        // status
        const statusCell = row.querySelector('.machine-status');
        if (statusCell) {
          statusCell.innerHTML = '';
          statusCell.appendChild(renderStatusBadge(m.status));
        }

        // ip
        const ipCell = row.querySelector('.machine-ip');
        if (ipCell) {
          ipCell.innerHTML = '';
          if (m.external_ip) {
            if (m.ingress_host) {
              const span = document.createElement('span');
              span.className = 'ip-pill';
              span.textContent = m.ingress_host + ' / ' + m.external_ip;
              ipCell.appendChild(span);
            } else {
              const span = document.createElement('span');
              span.className = 'ip-pill';
              span.textContent = m.external_ip;
              ipCell.appendChild(span);
            }
          } else if (m.ingress_host) {
            const span = document.createElement('span');
            span.className = 'ip-pill';
            span.textContent = m.ingress_host;
            ipCell.appendChild(span);
          } else if (m.access_scope === 'internal') {
            const nameCell = row.querySelector('.machine-name');
            const machineName = nameCell ? nameCell.textContent.trim() : '';
            const username = "{{ .Username }}";
            const span = document.createElement('span');
            span.className = 'ip-pill';
            span.textContent = username + '-' + machineName + '.' + username;
            ipCell.appendChild(span);
          } else {
            const span = document.createElement('span');
            span.className = 'ip-pill-muted';
            span.textContent = 'waiting...';
            ipCell.appendChild(span);
          }
        }
      }

      function hasPending() {
        return !!table.querySelector('.machine-status .status-badge.status-pending');
      }

      async function poll() {
        try {
          const resp = await fetch('/me/machines/json', { cache: 'no-store' });
          if (!resp.ok) return;
          const data = await resp.json();
          if (!Array.isArray(data)) return;

          const byId = new Map();
          data.forEach(m => byId.set(String(m.id), m));

          const rows = table.querySelectorAll('tbody tr[data-machine-id], tr[data-machine-id]');
          rows.forEach(row => {
            const id = row.getAttribute('data-machine-id');
            const m = byId.get(id);
            if (!m) return;
            updateRow(row, m);
          });
        } catch (e) {
          // молча игнорим
        }
      }

      if (hasPending()) {
        poll();
        setInterval(poll, POLL_INTERVAL_MS);
      }
    })();
  </script>
</body>
</html>
{{ end }}