{{ define "machine_new.tmpl" }}
<!DOCTYPE html>
<html>
<head>
  <title>{{ if .Machine }}Edit machine{{ else }}New machine{{ end }}</title>
  <style>
    :root {
      --bg-main: #0b0b0d;
      --bg-card: #141416;
      --bg-row-alt: #191b1f;
      --border-color: #26282f;
      --accent: #52e36a;
      --accent-soft: #3ac458;
      --text-main: #f5f5f7;
      --text-muted: #a0a3ad;
      --status-green: #2ecc71;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 24px;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background-color: var(--bg-main);
      color: var(--text-main);
    }

    h1 {
      margin: 0;
      font-size: 24px;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .page-header-title {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .page-subtitle {
      font-size: 12px;
      color: var(--text-muted);
    }

    .card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 16px;
      box-shadow: 0 6px 12px rgba(0,0,0,0.35);
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }

    .service-card {
      background-color: #191b1f;
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 12px;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: border-color 0.15s ease, transform 0.05s ease, box-shadow 0.15s ease, background-color 0.15s ease;
    }

    .service-card:hover {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px rgba(82, 227, 106, 0.25);
      background-color: #1f2025;
    }

    .service-card.selected {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px rgba(82, 227, 106, 0.4);
      background-color: #1c2320;
    }

    .service-icon {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--accent), #3ac458);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      color: #000;
      font-weight: 700;
    }

    .service-title {
      font-size: 14px;
      font-weight: 600;
    }

    .service-desc {
      font-size: 12px;
      color: var(--text-muted);
    }

    .service-meta {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .form-section {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--border-color);
    }

    .form-layout {
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(260px, 0.9fr);
      gap: 16px;
      align-items: flex-start;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .form-label {
      font-size: 12px;
      color: var(--text-muted);
    }

    .form-input, .form-select {
      background-color: #191b1f;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 6px 8px;
      color: var(--text-main);
      font-size: 13px;
    }

    .form-input:focus, .form-select:focus {
      outline: none;
      border-color: var(--accent);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 14px;
      font-size: 12px;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background-color 0.15s ease, transform 0.05s ease;
    }

    .btn-primary {
      background-color: var(--accent);
      color: #000;
      font-weight: 600;
    }

    .btn-primary:hover {
      background-color: var(--accent-soft);
    }

    .btn-muted {
      background-color: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border-color);
    }

    .btn-muted:hover {
      background-color: #1c1e23;
    }

    .actions {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
    }

    .hint {
      font-size: 11px;
      color: var(--text-muted);
    }

    .access-toggle {
      position: relative;
      display: flex;
      width: 240px;
      background-color: #191b1f;
      border-radius: 999px;
      padding: 2px;
      border: 1px solid var(--border-color);
      overflow: hidden;
    }

    .access-toggle-slider {
      position: absolute;
      top: 2px;
      bottom: 2px;
      left: 2px;
      width: calc(50% - 2px);
      background-color: var(--accent);
      border-radius: 999px;
      transition: transform 0.2s ease-in-out;
      z-index: 0;
    }

    .access-toggle.public-selected .access-toggle-slider {
      transform: translateX(100%);
    }

    .access-option {
      flex: 1 1 50%;
      position: relative;
      z-index: 1;
    }

    .access-option input[type="radio"] {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .access-option-label {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 4px 0;
      font-size: 11px;
      border-radius: 999px;
      border: 1px solid transparent;
      color: var(--text-muted);
      cursor: pointer;
      transition: color 0.15s ease;
      text-align: center;
    }

    .access-option input[type="radio"]:checked + .access-option-label {
      color: #000;
      font-weight: 600;
    }

    .tar-dropzone {
      position: relative;
      border-radius: 8px;
      border: 1px dashed var(--border-color);
      background-color: #191b1f;
      padding: 10px 12px;
      cursor: pointer;
      transition: border-color 0.15s ease, background-color 0.15s ease, box-shadow 0.15s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .tar-dropzone:hover {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px rgba(82, 227, 106, 0.25);
      background-color: #1f2025;
    }

    .tar-dropzone.drag-over {
      border-color: var(--accent);
      background-color: #1c2320;
      box-shadow: 0 0 0 1px rgba(82, 227, 106, 0.4);
    }

    .tar-file-input {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
    }

    .tar-dropzone-content {
      pointer-events: none;
    }

    .tar-dropzone-title {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-main);
    }

    .tar-dropzone-subtitle {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .tar-dropzone-filename {
      font-size: 11px;
      color: var(--accent);
      margin-top: 6px;
      word-break: break-all;
    }

    .image-panel {
      background-color: #191b1f;
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 12px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 16px;
    }

    .image-panel-title {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-main);
    }

    @media (max-width: 1100px) {
      .form-layout {
        grid-template-columns: 1fr;
      }
      .image-panel {
        margin-top: 8px;
      }
    }
  </style>
</head>
<body>
  <div class="page-header">
    <div class="page-header-title">
      <h1>{{ if .Machine }}Edit machine{{ else }}New machine{{ end }}</h1>
      <span class="page-subtitle">
        {{ if .Machine }}Update existing service configuration{{ else }}Choose a service type and configure its parameters{{ end }}
      </span>
    </div>
    <a href="/me/machines" class="btn btn-muted">← Back</a>
  </div>

  <div class="card">
    <!-- Service cards -->
    <div class="service-grid" id="service-grid">
      <div class="service-card"
           data-service="web"
           data-default-name="web"
           data-default-mode="app">
        <div class="service-icon">W</div>
        <div class="service-title">Web application</div>
        <div class="service-desc">Nginx-based HTTP service, suitable for simple web apps.</div>
        <div class="service-meta">image: nginx:stable-alpine</div>
      </div>

      <div class="service-card"
           data-service="api"
           data-default-name="api"
           data-default-mode="app">
        <div class="service-icon">A</div>
        <div class="service-title">API service</div>
        <div class="service-desc">Backend API service, can be customized with your image later.</div>
        <div class="service-meta">image: your-registry/api:latest</div>
      </div>

      <div class="service-card"
           data-service="worker"
           data-default-name="worker"
           data-default-mode="worker">
        <div class="service-icon">W</div>
        <div class="service-title">Background worker</div>
        <div class="service-desc">Non-HTTP background job or worker process.</div>
        <div class="service-meta">mode: worker</div>
      </div>
    </div>

    <form method="post"
          action="{{ if .Machine }}/me/machines/{{ .Machine.ID }}{{ else }}/me/machines{{ end }}"
          id="machine-form"
          enctype="multipart/form-data">
      <div class="form-section">
        <div class="form-layout">
          <!-- Левая часть -->
          <div>
            <div class="form-grid">
              <!-- Access -->
              <div class="form-field" id="access-field">
                <label class="form-label">Access</label>
                <div class="access-toggle" id="access-toggle">
                  <div class="access-toggle-slider"></div>
                  <div class="access-option">
                    <input type="radio" name="access_scope" id="access-internal"
                           value="internal"
                           {{ if or (not .Machine) (eq .Machine.AccessScope "internal") }}checked{{ end }}>
                    <label for="access-internal" class="access-option-label">Inside cluster</label>
                  </div>
                  <div class="access-option">
                    <input type="radio" name="access_scope" id="access-public"
                           value="public"
                           {{ if and .Machine (eq .Machine.AccessScope "public") }}checked{{ end }}>
                    <label for="access-public" class="access-option-label">Public</label>
                  </div>
                </div>
                <span class="hint">
                  Internal: only inside Kubernetes cluster. Public: accessible from outside.
                </span>
              </div>

              <!-- Selected service -->
              <div class="form-field">
                <label class="form-label">Selected service</label>
                <input type="text"
                       class="form-input"
                       id="service-kind-display"
                       value="{{ if .Machine }}{{ .Machine.ServiceKind }}{{ end }}"
                       placeholder="Choose a service above"
                       disabled>
                <input type="hidden"
                       name="service_kind"
                       id="service-kind"
                       value="{{ if .Machine }}{{ .Machine.ServiceKind }}{{ end }}">
              </div>

              <!-- Machine name -->
              <div class="form-field">
                <label class="form-label">Machine name</label>
                <input type="text"
                       name="name"
                       class="form-input"
                       id="machine-name"
                       value="{{ if .Machine }}{{ .Machine.Name }}{{ end }}"
                       placeholder="e.g. my-app"
                       required>
                <span class="hint">Will be used in resource name: hello-&lt;username&gt;-&lt;name&gt;</span>
              </div>

              <!-- Resources -->
              <div class="form-field">
                <label class="form-label">Resources</label>
                <select name="resources_preset" class="form-select" id="resources-preset">
                  <option value="small"
                    {{ if or (and (not .Machine) (eq .ResourcesPreset "")) (and .Machine (eq .Machine.ResourcesPreset "small")) }}selected{{ end }}>
                    Small (50m CPU / 64Mi RAM)
                  </option>
                  <option value="medium"
                    {{ if and .Machine (eq .Machine.ResourcesPreset "medium") }}selected{{ end }}>
                    Medium (100m CPU / 128Mi RAM)
                  </option>
                  <option value="large"
                    {{ if and .Machine (eq .Machine.ResourcesPreset "large") }}selected{{ end }}>
                    Large (250m CPU / 256Mi RAM)
                  </option>
                </select>
                <span class="hint">Controls CPU and memory for the pod.</span>
              </div>

              <!-- Container port -->
              <div class="form-field">
                <label class="form-label">Container port</label>
                <input type="number"
                       name="container_port"
                       id="container-port"
                       class="form-input"
                       min="1" max="65535"
                       value="{{ if .Machine }}{{ .Machine.ContainerPort }}{{ else }}80{{ end }}">
                <span class="hint">
                  Port your app listens on inside the container (80 for Web, 8080 for API by default).
                </span>
              </div>

              <!-- Service port -->
              <div class="form-field">
                <label class="form-label">Service port</label>
                <input type="number"
                       name="service_port"
                       id="service-port"
                       class="form-input"
                       min="1" max="65535"
                       value="{{ if .Machine }}{{ .Machine.ServicePort }}{{ else }}80{{ end }}">
                <span class="hint">
                  Port exposed by the Kubernetes Service (defaults to same as container port).
                </span>
              </div>

              <!-- Ingress toggle -->
              <div class="form-field" id="ingress-options">
                <label class="form-label">
                  <input type="checkbox"
                         name="enable_ingress"
                         id="enable-ingress"
                         {{ if and .Machine .Machine.IngressHost }}checked{{ end }}>
                  Expose via Ingress (DNS)
                </label>
                <span class="hint">
                  When enabled, traffic goes through Traefik by DNS host.
                </span>
              </div>

              <!-- Ingress host -->
              <div class="form-field" id="ingress-host-field">
                <label class="form-label" for="ingress-host">DNS name (host)</label>
                <input type="text"
                       name="ingress_host"
                       id="ingress-host"
                       class="form-input"
                       value="{{ if and .Machine .Machine.IngressHost }}{{ .Machine.IngressHost }}{{ end }}"
                       placeholder="e.g. api-<username>.kyna.local">
                <span class="hint">
                  Required when Ingress is enabled. Must resolve to your server IP.
                </span>
              </div>
            </div>

            <div class="actions">
              <a href="/me/machines" class="btn btn-muted">Cancel</a>
              <button type="submit" class="btn btn-primary">
                {{ if .Machine }}Update machine{{ else }}Create machine{{ end }}
              </button>
            </div>
          </div>

          <!-- Правая часть: Images -->
          <div class="image-panel">
            <div class="image-panel-title">Images</div>

            <div class="form-field">
              <label class="form-label">Image (optional)</label>
              <input type="text"
                     name="image"
                     class="form-input"
                     id="machine-image"
                     value="{{ if and .Machine .Machine.Image }}{{ .Machine.Image }}{{ end }}"
                     placeholder="e.g. nginx:stable-alpine or ghcr.io/user/app:v1.0.2">
              <span class="hint">
                If empty, we use a default image for this preset. If you upload a .tar, we load it and store its repo:tag here.
              </span>
            </div>

            <div class="form-field">
              <label class="form-label">Docker image (.tar)</label>
              <div id="tar-dropzone" class="tar-dropzone">
                <input type="file"
                       name="image_tar"
                       id="image-tar-input"
                       class="tar-file-input"
                       accept=".tar,.tar.gz,.tgz,.tar.zst,.tar.bz2">
                <div class="tar-dropzone-content">
                  <div class="tar-dropzone-title">Drop .tar file here</div>
                  <div class="tar-dropzone-subtitle">…or click to choose from disk</div>
                  <div class="tar-dropzone-filename" id="tar-filename">No file selected</div>
                </div>
              </div>
              <span class="hint">
                Export via: docker save -o my-image.tar your-image:tag, then upload this file.
              </span>
            </div>
          </div>
        </div>
      </div>
    </form>
  </div>

  <script>
    (function() {
      const isEditing = {{ if .Machine }}true{{ else }}false{{ end }};

      const cards = document.querySelectorAll('.service-card');
      const serviceKindInput = document.getElementById('service-kind');
      const serviceKindDisplay = document.getElementById('service-kind-display');
      const nameInput = document.getElementById('machine-name');
      const containerPortInput = document.getElementById('container-port');
      const servicePortInput = document.getElementById('service-port');

      const accessField = document.getElementById('access-field');
      const accessInternal = document.getElementById('access-internal');
      const accessPublic = document.getElementById('access-public');
      const accessToggle = document.getElementById('access-toggle');

      const ingressOptions = document.getElementById('ingress-options');
      const ingressToggle = document.getElementById('enable-ingress');
      const ingressHostField = document.getElementById('ingress-host-field');

      function setDefaultsForKind(kind) {
        if (!containerPortInput || !servicePortInput) return;

        // при edit не трогаем существующие значения
        if (isEditing) return;

        if (kind === 'web') {
          if (!containerPortInput.value) {
            containerPortInput.value = 80;
          }
          if (!servicePortInput.value) {
            servicePortInput.value = 80;
          }
        } else if (kind === 'api') {
          if (!containerPortInput.value) {
            containerPortInput.value = 8080;
          }
          if (!servicePortInput.value) {
            servicePortInput.value = 8080;
          }
        }
      }

      function updateFormForKind(kind) {
        const isApi = (kind === 'api');

        if (isApi) {
          accessField.style.display = 'flex';
        } else {
          accessField.style.display = 'none';
          if (accessInternal) accessInternal.checked = true;
          if (accessPublic) accessPublic.checked = false;
        }

        updateIngressVisibility();
        updateAccessSlider();
      }

      function updateIngressVisibility() {
        if (!serviceKindInput) return;

        const kind = serviceKindInput.value;
        const isApi = (kind === 'api');
        const isPublic = accessPublic && accessPublic.checked;

        if (isApi && isPublic) {
          ingressOptions.style.display = 'flex';
          if (ingressToggle && ingressToggle.checked) {
            ingressHostField.style.display = 'flex';
          } else {
            ingressHostField.style.display = 'none';
          }
        } else {
          ingressOptions.style.display = 'none';
          ingressHostField.style.display = 'none';
          if (ingressToggle) ingressToggle.checked = false;
        }
      }

      function updateAccessSlider() {
        if (!accessToggle || !accessPublic) return;
        if (accessPublic.checked) {
          accessToggle.classList.add('public-selected');
        } else {
          accessToggle.classList.remove('public-selected');
        }
      }

      cards.forEach(card => {
        card.addEventListener('click', () => {
          // запрещаем смену сервиса в режиме edit
          if (isEditing) {
            return;
          }

          cards.forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');

          const kind = card.getAttribute('data-service');
          const defaultName = card.getAttribute('data-default-name') || "";

          if (serviceKindInput) serviceKindInput.value = kind;
          if (serviceKindDisplay) {
            const title = card.querySelector('.service-title').textContent;
            serviceKindDisplay.value = title;
          }

          if (!nameInput.value) {
            nameInput.value = defaultName;
          }

          setDefaultsForKind(kind);
          updateFormForKind(kind);
        });
      });

      // инициализация для edit
      (function initSelectedServiceCard() {
        if (!serviceKindInput || !serviceKindInput.value) return;
        const current = serviceKindInput.value;
        cards.forEach(card => {
          if (card.getAttribute('data-service') === current) {
            card.classList.add('selected');
          } else {
            card.classList.remove('selected');
          }
        });
        updateFormForKind(current);
      })();

      if (accessInternal && accessPublic) {
        accessInternal.addEventListener('change', () => {
          updateAccessSlider();
          updateIngressVisibility();
        });
        accessPublic.addEventListener('change', () => {
          updateAccessSlider();
          updateIngressVisibility();
        });
        updateAccessSlider();
      }

      if (ingressToggle) {
        ingressToggle.addEventListener('change', updateIngressVisibility);
      }

      // TAR dropzone дальше оставляем как было...
    })();
  </script>
</body>
</html>
{{ end }}