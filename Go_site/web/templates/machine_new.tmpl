{{ define "machine_new.tmpl" }}
<!DOCTYPE html>
<html>
<head>
  <title>New machine</title>
  <style>
    :root {
      --bg-main: #0b0b0d;
      --bg-card: #141416;
      --bg-row-alt: #191b1f;
      --border-color: #26282f;
      --accent: #52e36a;
      --accent-soft: #3ac458;
      --text-main: #f5f5f7;
      --text-muted: #a0a3ad;
      --status-green: #2ecc71;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 24px;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background-color: var(--bg-main);
      color: var(--text-main);
    }

    h1 {
      margin: 0;
      font-size: 24px;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .page-header-title {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .page-subtitle {
      font-size: 12px;
      color: var(--text-muted);
    }

    .card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 16px;
      box-shadow: 0 6px 12px rgba(0,0,0,0.35);
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }

    .service-card {
      background-color: #191b1f;
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 12px;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: border-color 0.15s ease, transform 0.05s ease, box-shadow 0.15s ease, background-color 0.15s ease;
    }

    .service-card:hover {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px rgba(82, 227, 106, 0.25);
      background-color: #1f2025;
    }

    .service-card.selected {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px rgba(82, 227, 106, 0.4);
      background-color: #1c2320;
    }

    .service-icon {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--accent), #3ac458);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      color: #000;
      font-weight: 700;
    }

    .service-title {
      font-size: 14px;
      font-weight: 600;
    }

    .service-desc {
      font-size: 12px;
      color: var(--text-muted);
    }

    .service-meta {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .form-section {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--border-color);
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .form-label {
      font-size: 12px;
      color: var(--text-muted);
    }

    .form-input, .form-select {
      background-color: #191b1f;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 6px 8px;
      color: var(--text-main);
      font-size: 13px;
    }

    .form-input:focus, .form-select:focus {
      outline: none;
      border-color: var(--accent);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 14px;
      font-size: 12px;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background-color 0.15s ease, transform 0.05s ease;
    }

    .btn-primary {
      background-color: var(--accent);
      color: #000;
      font-weight: 600;
    }

    .btn-primary:hover {
      background-color: var(--accent-soft);
    }

    .btn-muted {
      background-color: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border-color);
    }

    .btn-muted:hover {
      background-color: #1c1e23;
    }

    .actions {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
    }

    .hint {
      font-size: 11px;
      color: var(--text-muted);
    }
  </style>
</head>
<body>
  <div class="page-header">
    <div class="page-header-title">
      <h1>New machine</h1>
      <span class="page-subtitle">Choose a service type and configure its parameters</span>
    </div>
    <a href="/me/machines" class="btn btn-muted">← Back</a>
  </div>

  <div class="card">
    <!-- Сетка сервисов -->
    <div class="service-grid" id="service-grid">
      <div class="service-card" data-service="web" data-default-name="web" data-default-mode="app">
        <div class="service-icon">W</div>
        <div class="service-title">Web application</div>
        <div class="service-desc">Nginx-based HTTP service, suitable for simple web apps.</div>
        <div class="service-meta">image: nginx:stable-alpine</div>
      </div>

      <div class="service-card" data-service="api" data-default-name="api" data-default-mode="app">
        <div class="service-icon">A</div>
        <div class="service-title">API service</div>
        <div class="service-desc">Backend API service, can be customized with your image later.</div>
        <div class="service-meta">image: your-registry/api:latest</div>
      </div>

      <div class="service-card" data-service="worker" data-default-name="worker" data-default-mode="worker">
        <div class="service-icon">W</div>
        <div class="service-title">Background worker</div>
        <div class="service-desc">Non-HTTP background job or worker process.</div>
        <div class="service-meta">mode: worker</div>
      </div>
    </div>

    <!-- Форма конфигурации -->
    <form method="post" action="/me/machines" id="machine-form">
      <div class="form-section">
        <div class="form-grid">
          <div class="form-field">
            <label class="form-label">Selected service</label>
            <input type="text" class="form-input" id="service-kind-display" value="" placeholder="Choose a service above" disabled>
            <input type="hidden" name="service_kind" id="service-kind">
          </div>

          <div class="form-field">
            <label class="form-label">Machine name</label>
            <input type="text" name="name" class="form-input" id="machine-name" placeholder="e.g. my-app" required>
            <span class="hint">Will be used in resource name: hello-&lt;username&gt;-&lt;name&gt;</span>
          </div>


          <div class="form-field">
            <label class="form-label">Resources</label>
            <select name="resources_preset" class="form-select" id="resources-preset">
              <option value="small" selected>Small (50m CPU / 64Mi RAM)</option>
              <option value="medium">Medium (100m CPU / 128Mi RAM)</option>
              <option value="large">Large (250m CPU / 256Mi RAM)</option>
            </select>
            <span class="hint">Controls CPU and memory for the pod.</span>
          </div>

          <div class="form-field">
            <label class="form-label">Image (optional)</label>
            <input type="text" name="image" class="form-input" id="machine-image"
                  placeholder="e.g. nginx:stable-alpine or ghcr.io/user/app:v1.0.2">
            <span class="hint">If empty, we use a default image for this preset.</span>
          </div>


        </div>

        <div class="actions">
          <a href="/me/machines" class="btn btn-muted">Cancel</a>
          <button type="submit" class="btn btn-primary">Create machine</button>
        </div>
      </div>
    </form>
  </div>

  <script>
    (function() {
      const cards = document.querySelectorAll('.service-card');
      const serviceKindInput = document.getElementById('service-kind');
      const serviceKindDisplay = document.getElementById('service-kind-display');
      const nameInput = document.getElementById('machine-name');

      cards.forEach(card => {
        card.addEventListener('click', () => {
          // снять выделение со всех
          cards.forEach(c => c.classList.remove('selected'));

          // выделить текущую
          card.classList.add('selected');

          const kind = card.getAttribute('data-service');
          const defaultName = card.getAttribute('data-default-name') || "";
          const defaultMode = card.getAttribute('data-default-mode') || "app";

          serviceKindInput.value = kind;
          serviceKindDisplay.value = card.querySelector('.service-title').textContent;

          if (!nameInput.value) {
            nameInput.value = defaultName;
          }
        });
      });
    })();
  </script>
</body>
</html>
{{ end }}